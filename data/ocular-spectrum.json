        {"id": "B", "weights": [0.15, 0.35, 0.95]},
        {"id": "G", "weights": [0.20, 0.75, 0.30]}
      ],
      "display_matrix": [[0.35, 0.25, 0.55], [0.15, 0.80, 0.45], [0.25, 0.22, 1.28]],
      "teach": "No red receptor — UV bullseyes and sky polarization cues visible."
    },
    "mammal_night": {
      "label": "Nocturnal mammal — rod dominant",
      "class": "mammal",
      "engine": "cone_v2",
      "mode": "luminance",
      "range_nm": [400, 650],
      "adaptation": 0.22,
      "receptors": [{"id": "rod", "peak_nm": 500}],
      "teach": "Scotopic rods — luminance and motion, color drained, contrast lifted."
    },
    "raptor": {
      "label": "Raptor — foveal tetrachromat",
      "class": "avian",
      "engine": "cone_v2",
      "range_nm": [300, 700],
      "adaptation": 0.11,
      "uv_sensitive": true,
      "foveal": true,
      "foveal_strength": 0.72,
      "receptors": [
        {"id": "L", "peak_nm": 565}, {"id": "M", "peak_nm": 503},
        {"id": "S", "peak_nm": 450}, {"id": "UV", "peak_nm": 365}
      ],
      "cones": [
        {"id": "L", "weights": [0.52, 0.34, 0.06]},
        {"id": "M", "weights": [0.08, 0.82, 0.08]},
        {"id": "S", "weights": [0.04, 0.16, 0.98]},
        {"id": "UV", "weights": [0.02, 0.12, 1.08]}
      ],
      "display_matrix": [[0.82, 0.12, 0.14], [0.04, 0.98, 0.12], [0.12, 0.18, 1.22]],
