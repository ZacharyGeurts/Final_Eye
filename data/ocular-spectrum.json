      "cones": [
        {"id": "L", "weights": [0.62, 0.28, 0.06]},
        {"id": "M", "weights": [0.18, 0.72, 0.12]},
        {"id": "S", "weights": [0.08, 0.30, 0.88]},
        {"id": "UV", "weights": [0.04, 0.22, 0.95]}
      ],
      "display_matrix": [[0.90, 0.12, 0.08], [0.12, 0.92, 0.18], [0.08, 0.28, 1.05]],
      "teach": "Green-yellow discrimination boosted — basking terrain and mate patterns pop."
    },
    "snake_pit": {
      "label": "Pit viper — thermal + visible",
      "class": "reptile",
      "engine": "cone_v2",
      "mode": "thermal_overlay",
      "range_nm": [400, 700],
      "adaptation": 0.18,
      "receptors": [
        {"id": "visible", "peak_nm": 550},
        {"id": "pit", "peak_nm": 10000, "role": "infrared pits"}
