      "cones": [
        {"id": "L", "weights": [0.55, 0.35, 0.10]},
        {"id": "M", "weights": [0.15, 0.70, 0.15]},
        {"id": "S", "weights": [0.05, 0.15, 0.80]}
      ],
      "teach": "Thermal colormap blended with visible cones — heat signatures overlay scene."
    },
    "fish": {
      "label": "Fish — underwater spectrum",
      "class": "fish",
      "engine": "cone_v2",
      "range_nm": [400, 680],
      "adaptation": 0.16,
      "receptors": [
        {"id": "L", "peak_nm": 600}, {"id": "M", "peak_nm": 530}, {"id": "S", "peak_nm": 450}
      ],
      "cones": [
        {"id": "L", "weights": [0.35, 0.30, 0.08]},
        {"id": "M", "weights": [0.10, 0.82, 0.22]},
        {"id": "S", "weights": [0.05, 0.25, 1.05]}
      ],
      "display_matrix": [[0.55, 0.15, 0.05], [0.08, 0.95, 0.28], [0.05, 0.32, 1.18]],
      "teach": "Red absorbed underwater — blue-green channel dominance."
